# Normalize line endings to LF on checkout for cross-platform consistency
* text=auto eol=lf

# Force LF for shell scripts and Dockerfiles
*.sh text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Force CRLF for Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
*.zip binary
